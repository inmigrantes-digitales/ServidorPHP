# Copiar este archivo como .env y completar valores reales

# Base de datos
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=
# DB_CHARSET=utf8mb4

# Seguridad
# Genera un secreto largo y aleatorio (minimo 32 caracteres)
JWT_SECRET=
JWT_EXPIRATION=604800

# CORS
# Produccion: https://tu-frontend.com
CORS_ORIGIN=*

# IA (opcionales)
GROQ_API_KEY=
GEMINI_API_KEY=
